{
  "name": "webapp",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve web-app --port 4200",
    "start:ha": "ng serve ha-app --port 4201",
    "build": "ng build web-app --configuration production",
    "build:ha": "ng build ha-app --configuration production --base-href ./ --deploy-url ./",
    "build:all": "npm run build && npm run build:ha",
    "lint": "eslint .",
    "watch": "ng build web-app --watch --configuration development",
    "watch:ha": "ng build ha-app --watch --configuration development",
    "test": "ng test",
    "test:ha-ingress": "playwright test --config playwright.ha-ingress.config.ts",
    "test:ha-ingress:headed": "playwright test --config playwright.ha-ingress.config.ts --headed"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/cdk": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/material": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@playwright/test": "^1.60.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "^19.8.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.0.0"
  },
  "overrides": {
    "tar": "^7.5.13",
    "serialize-javascript": "^7.0.5",
    "postcss": "^8.5.12",
    "sockjs": {
      "uuid": "^14.0.0"
    }
  }
}
